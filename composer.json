{
    "name": "phattarachai/laravel-exception-log",
    "description": "Log exceptions to database with smart email alerts and mute capability",
    "keywords": ["laravel", "exception", "logging", "error-tracking"],
    "license": "MIT",
    "authors": [
        {
            "name": "Phattarachai",
            "email": "pc@phattarachai.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/notifications": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Phattarachai\\ExceptionLog\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phattarachai\\ExceptionLog\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Phattarachai\\ExceptionLog\\ExceptionLogServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
